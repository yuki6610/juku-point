{
  "hosting": {
    "source": ".",
    "frameworksBackend": {
      "region": "us-east1"
    }
  },
  "apphosting": {
    "backendId": "juku-point",
    "rootDir": ".",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "functions"
    ],
    "alwaysDeployFromSource": true
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
