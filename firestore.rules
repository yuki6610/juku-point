rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // The app's ranking and admin checks currently require signed-in users to
    // read these collections. Only an existing admin can change admin records.
    match /admins/{adminId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update, delete: if isOwner(userId) || isAdmin();

      match /{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /rewards/{rewardId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /admin_data/{documentId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /hallOfFame/{seasonId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /illegal_checkins/{recordId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    match /schools/{schoolId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /universities/{universityId} {
      allow read: if signedIn();
      allow write: if isAdmin();

      match /admissions/{admissionId} {
        allow read: if signedIn();
        allow write: if isAdmin();
      }
    }

    // Everything not explicitly listed above stays private.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
